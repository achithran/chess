# ── Copy this file to .env and fill in your values ──────────────────────────
# On Railway: set these as environment variables in each service's settings.

# General
ENVIRONMENT=production
SECRET_KEY=generate-a-long-random-string-here

# Database
# Local:   postgresql+asyncpg://user:password@localhost:5432/checkmate
# Railway: add the PostgreSQL plugin → it injects DATABASE_URL automatically.
#          The app auto-converts postgresql:// → postgresql+asyncpg:// so no
#          manual editing of the Railway-provided URL is needed.
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Redis
# Local:   redis://localhost:6379/0
# Railway: add the Redis plugin → it injects REDIS_URL automatically.
#          CELERY_BROKER_URL and CELERY_RESULT_BACKEND default to REDIS_URL
#          if not set — so you only need to set REDIS_URL on Railway.
REDIS_URL=redis://default:password@host:6379

# AI — Groq (free tier at console.groq.com — primary AI provider)
GROQ_API_KEY=gsk_...

# AI — OpenAI (optional fallback if Groq is unavailable)
OPENAI_API_KEY=sk-...

# TTS — Google Cloud (preferred for Indian languages — native Malayalam/Tamil Wavenet voices)
# Setup: console.cloud.google.com → Enable "Cloud Text-to-Speech API" → Credentials → API Key
GOOGLE_TTS_API_KEY=AIza...

# TTS — ElevenLabs (fallback, free 10K chars/month at elevenlabs.io)
ELEVENLABS_API_KEY=sk_...

# CORS — comma-separated list of allowed frontend origins
# Railway: set this to your frontend Railway URL after first deploy, e.g.:
#   BACKEND_CORS_ORIGINS=https://chess-frontend.up.railway.app,http://localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:3000

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payments (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
