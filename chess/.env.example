# ── Copy this file to .env and fill in your values ──────────────────────────

# General
ENVIRONMENT=production
SECRET_KEY=generate-a-long-random-string-here

# Database (get from Supabase → Project Settings → Database → Connection string)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Redis (get from Upstash → Redis database → .env tab)
REDIS_URL=redis://default:password@host.upstash.io:6379

# AI — Groq (free at console.groq.com)
GROQ_API_KEY=gsk_...

# AI — OpenAI (optional, Groq is used as primary)
OPENAI_API_KEY=sk-...

# TTS — ElevenLabs (free 10K chars/month at elevenlabs.io)
ELEVENLABS_API_KEY=sk_...

# CORS — add your Vercel frontend URL here
BACKEND_CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payments (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
